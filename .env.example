# Supabase Configuration
# Obtén estos valores desde tu proyecto en Supabase Dashboard -> Settings -> API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_BASE_DOMAIN=your-domain.com

# Cloudinary Configuration
# Obtén estos valores desde Cloudinary: https://cloudinary.com
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# Optional: if you need to keep a compatibility variable for tenant detection
# NEXT_PUBLIC_BASE_DOMAIN=your-domain.com
